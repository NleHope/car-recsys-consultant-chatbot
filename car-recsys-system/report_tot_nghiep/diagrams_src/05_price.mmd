flowchart TB
  subgraph s1["Stage 1 · Data Extraction & Preprocessing"]
    direction LR
    pg[("PostgreSQL<br/>(production)")]:::store
    csv["master_car_dataset_cleaned.csv<br/>5,201 rows × 19 cols<br/>engine: 443 → 135 labels"]:::art
    pg -->|SQLAlchemy| csv
  end

  subgraph s2["Stage 2 · Feature Pipeline"]
    direction LR
    fe["Feature Engineering (~60 features)<br/>title parsing · transmission 108→5<br/>color 923→9 · price anchors<br/>mileage percentile · engine tier"]:::proc
    dino["DINOv2-Small<br/>384-d image embeddings<br/>→ PCA (24–96 comps)"]:::proc
    te["Smoothed target encoding<br/>(alpha tuned by Optuna)"]:::proc
    fe ~~~ dino ~~~ te
  end

  subgraph s3["Stage 3 · Training — Optuna 80 trials · 3-fold CV"]
    direction LR
    cb["CatBoost"]:::model
    lgb["LightGBM"]:::model
    xgb["XGBoost"]:::model
    meta["Ridge meta-model<br/>weights 0.461 · 0.426 · 0.192"]:::meta
    cb --> meta
    lgb --> meta
    xgb --> meta
  end

  subgraph s4["Stage 4 · Serving"]
    direction LR
    art["model_artifacts/<br/>.cbm · .txt · .json · .pkl"]:::art
    api["FastAPI · Cloud Run<br/>POST /predict_price<br/>price ± 9.83% band"]:::svc
    sell["Sell page<br/>'Estimate with AI'"]:::svc
    art --> api --> sell
  end

  csv --> s2
  s2 --> s3
  meta --> art

  classDef store fill:#F4F4F5,stroke:#78716c,stroke-width:1.5px,color:#1c1917;
  classDef art fill:#efe7d6,stroke:#8a6100,stroke-width:1.5px,color:#1c1917;
  classDef proc fill:#FDF6E8,stroke:#A87601,stroke-width:1.5px,color:#1c1917;
  classDef model fill:#FBF7EF,stroke:#A87601,stroke-width:2px,color:#1c1917;
  classDef meta fill:#FDF6E8,stroke:#8a6100,stroke-width:2px,color:#1c1917;
  classDef svc fill:#FBF7EF,stroke:#A87601,stroke-width:2px,color:#1c1917;
