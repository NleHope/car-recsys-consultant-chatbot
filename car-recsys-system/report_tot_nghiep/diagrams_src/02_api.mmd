  end
  subgraph sv["4 · Service Layer"]
    s1["AuthService"]:::s
    s2["SearchService"]:::s
    s3["RecommendationEngine"]:::s
    s4["ChatbotService"]:::s
  end

  data[("AlloyDB · Qdrant")]

  req --> mw --> au --> rt
  r1 --> s1
  r2 --> s2
  r3 --> s3
  r4 --> s4
  sv --> data

