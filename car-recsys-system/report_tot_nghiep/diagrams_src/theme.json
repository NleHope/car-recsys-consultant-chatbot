{
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Helvetica, Arial, sans-serif",
    "fontSize": "20px",
    "primaryColor": "#FBF7EF",
    "primaryBorderColor": "#A87601",
    "primaryTextColor": "#1c1917",
    "lineColor": "#8a6100",
    "clusterBkg": "#FAFAF9",
    "clusterBorder": "#a8a29e",
    "edgeLabelBackground": "#ffffff"
  },
  "flowchart": {
    "curve": "linear",
    "nodeSpacing": 35,
    "rankSpacing": 45,
    "padding": 14,
    "subGraphTitleMargin": { "top": 8, "bottom": 12 },
    "useMaxWidth": false
  }
}
